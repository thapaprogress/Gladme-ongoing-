# GladME Studio V4 — Environment Configuration
# Copy this to .env and fill in your values

# Environment: "development" or "production"
# In production, JWT_SECRET must be changed from the default
ENV=development

JWT_SECRET=your-secret-key-change-this-in-production
DATABASE_URL=sqlite:///./gladme_v4.db
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_MODEL=gemma4:latest
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SANDBOX_TYPE=docker
RATE_LIMIT_PER_MINUTE=30

# Optional cloud LLM keys (server-only, never sent to frontend)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional MCP servers (format: name=url;name2=url2)
MCP_SERVERS=